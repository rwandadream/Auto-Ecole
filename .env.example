# ============================================================
# Variables d'environnement SARAH AUTO
# Copiez ce fichier en .env.local et renseignez vos valeurs
# ============================================================

# Supabase — clés publiques (côté client)
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_VOTRE_CLE_PUBLIQUE

# Supabase — clé service role (côté serveur uniquement, ne jamais exposer au client)
# Requise pour les routes /api/admin/users (création / suppression d'utilisateurs)
SUPABASE_SERVICE_ROLE_KEY=VOTRE_SERVICE_ROLE_KEY
